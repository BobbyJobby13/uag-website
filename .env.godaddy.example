# Build-time API target for GoDaddy-hosted frontend.
# This should be the absolute URL of your backend/API.
# If you keep the Vercel backend running, use that URL here.
VITE_API_BASE_URL=https://uag-website-virid.vercel.app/api

# GoDaddy FTP credentials (used by deploy-godaddy.cjs)
GODADDY_FTP_HOST=your-cpanel-domain.com
GODADDY_FTP_USER=your-ftp-username
GODADDY_FTP_PASS=your-ftp-password
GODADDY_FTP_DIR=public_html

# Optional: override default FTP port (21) or disable FTPS
# GODADDY_FTP_PORT=21
# GODADDY_FTP_SECURE=true
